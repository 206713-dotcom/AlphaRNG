PORT=4173
# Local dev should stay 127.0.0.1. Public hosts usually need HOST=0.0.0.0.
HOST=127.0.0.1
NODE_ENV=development

# Required for Gemini-powered server-side word/badge analysis.
GEMINI_API_KEY=your_google_ai_studio_key_here
GEMINI_MODEL=gemini-flash-lite-latest
GEMINI_TIMEOUT_MS=5500
GEMINI_CACHE_TTL_MS=3600000
GEMINI_CACHE_MAX=500

# Required for real magic-link login emails in multiplayer deployments.
# Option A: Resend
RESEND_API_KEY=your_resend_key_here
TWO_FACTOR_FROM_EMAIL=AlphaRNG <noreply@yourdomain.com>

# Option B: SMTP sender. This can send magic links to any valid email address.
# Gmail is shown as an example sender. For Gmail, use a Google App Password,
# not your normal Gmail password:
# Google Account -> Security -> 2-Step Verification -> App passwords.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=sender@example.com
SMTP_PASS=your_smtp_or_google_app_password
SMTP_FROM=AlphaRNG <sender@example.com>

PUBLIC_BASE_URL=https://your-alpharng-domain.example
ALLOWED_ORIGIN=https://your-alpharng-domain.example
TRUST_PROXY=true
CONNECT_SRC=https://your-alpharng-domain.example
MAX_BODY_BYTES=256000

# Public-server safety limits.
API_RATE_LIMIT=240
ROLL_RATE_LIMIT=90
AI_RATE_LIMIT=60
AUTH_RATE_LIMIT=6
LEADERBOARD_RATE_LIMIT=60

# For local development only. Do not enable this in production.
# Without real email settings, the dev server prints/returns the magic link for local testing.
RETURN_DEV_MAGIC_LINKS=true
RETURN_DEV_2FA_CODES=true
